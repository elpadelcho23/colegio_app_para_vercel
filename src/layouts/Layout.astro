---
import Navigation from '../components/Navigation.astro';
import AppShell from '../components/spa/AppShell.astro';
import '../styles/global.css';
import { resolveInitialView, type SpaViewId } from '../scripts/spa-config.ts';

interface Props {
  title: string;
  description?: string;
  useSpa?: boolean;
}

const {
  title,
  description = 'Gestion escolar para docentes: asistencia, notas y seguimiento academico.',
  useSpa,
} = Astro.props;

const currentPath = Astro.url.pathname;
const user = Astro.locals.user;
const isAdminPage = currentPath.startsWith('/admin');
const spaEnabled = useSpa ?? Boolean(user && !isAdminPage);
const initialView = spaEnabled
  ? resolveInitialView(currentPath, Astro.url.search)
  : 'panel';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#226c5f" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Aula Clara</title>
  </head>
  <body class="app-body" data-spa-enabled={spaEnabled ? 'true' : 'false'}>
    <a class="skip-link" href="#main-content">Ir al contenido principal</a>
    <Navigation currentPath={currentPath} spaEnabled={spaEnabled} />
    <div class="app-main" id="main-content">
      {spaEnabled ? (
        <AppShell initialView={initialView as SpaViewId} />
      ) : (
        <slot />
      )}
    </div>
    <script define:vars={{ user, initialView, spaEnabled }}>
      window.__AULA_CLARA_USER__ = user;
      window.__AULA_CLARA_SPA__ = { enabled: spaEnabled, initialView };
    </script>
    <script>
      import '../scripts/school-app.js';
    </script>
  </body>
</html>
