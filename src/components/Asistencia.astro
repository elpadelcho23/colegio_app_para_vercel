---
import Navigation from '../components/Navigation.astro';
import '../styles/global.css';
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Asistencias | SGE</title>
<style>
        .filtros {
            margin: 0;
        }

        #lista-asistencia {
            display: flex;
            flex-direction: column;
            gap: 0;
            padding: 0;
        }

        .alumno-fila {
            display: flex;
            flex-direction: column;
            gap: var(--space-3);
            padding: var(--space-4) 0;
            border-bottom: 1px solid var(--line);
        }

        @media (min-width: 560px) {
            .alumno-fila {
                flex-direction: row;
                align-items: center;
                justify-content: space-between;
            }
        }

        .alumno-info {
            flex: 1;
            min-width: 0;
        }

        .alumno-info strong {
            font-size: 0.98rem;
        }

        .alumno-info small {
            color: var(--muted);
            font-size: 0.82rem;
        }

        .estado-asistencia {
            display: inline-block;
            margin-top: 0.35rem;
            padding: 0.25rem 0.65rem;
            border-radius: 999px;
            font-size: 0.78rem;
            background: var(--surface-2);
            color: var(--muted);
        }

        .estado-asistencia.presente {
            background: color-mix(in srgb, var(--ok) 18%, var(--surface));
            color: var(--ok);
        }

        .estado-asistencia.ausente {
            background: color-mix(in srgb, var(--danger) 16%, var(--surface));
            color: var(--danger);
        }

        .lista-acciones {
            display: flex;
            gap: var(--space-2);
            flex-wrap: wrap;
        }

        .btn-sm {
            min-height: 40px;
            padding: 0.45rem 0.8rem;
            font-size: 0.85rem;
        }

        .btn-presente {
            color: #fff;
            background: var(--ok);
        }

        .btn-ausente {
            color: #fff;
            background: var(--danger);
        }

        .btn-quitar {
            color: var(--ink);
            background: color-mix(in srgb, var(--warning) 22%, var(--surface));
        }

        .btn-perfil {
            color: var(--ink);
            background: var(--surface-2);
            border: 1px solid var(--line);
        }

        .modal-content {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: calc(var(--radius) + 2px);
            padding: var(--space-5);
            width: min(94vw, 460px);
            margin: auto;
            position: relative;
            color: var(--ink);
            box-shadow: var(--shadow);
        }

        .modal-content h2 {
            font-size: 1.2rem;
            margin-bottom: var(--space-2);
        }

        .modal-content h3 {
            font-size: 1rem;
            color: var(--muted);
            margin: var(--space-4) 0 var(--space-2);
        }

        .btn-cerrar {
            position: absolute;
            top: var(--space-3);
            right: var(--space-3);
            min-height: 36px;
            width: 36px;
            border: 1px solid var(--line);
            border-radius: 50%;
            background: var(--surface-2);
            color: var(--muted);
            cursor: pointer;
        }

        .modal-progreso {
            display: inline-block;
            background: var(--surface-2);
            padding: 0.35rem 0.85rem;
            border-radius: 999px;
            font-size: 0.88rem;
            color: var(--muted);
            margin-bottom: var(--space-4);
        }

        .modal-avatar-wrap {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: var(--space-2);
            margin-bottom: var(--space-5);
        }

        .avatar {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            border: 2px solid var(--line);
            object-fit: cover;
            background: var(--surface-2);
        }

        .modal-acciones-lista {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-3);
            margin-bottom: var(--space-4);
        }

        .modal-acciones-lista .btn {
            width: 100%;
            min-height: 56px;
            font-size: 1.05rem;
        }

        .modal-nav,
        .modal-footer {
            display: flex;
            gap: var(--space-2);
            flex-wrap: wrap;
        }

        .modal-nav {
            justify-content: space-between;
            padding-top: var(--space-4);
            border-top: 1px solid var(--line);
        }

        .modal-footer {
            justify-content: center;
            margin-top: var(--space-3);
        }

        .modal-resumen {
            display: none;
            margin: var(--space-3) 0 var(--space-2);
            padding: var(--space-3);
            border-radius: var(--radius);
            background: var(--surface-muted);
            color: var(--muted);
            font-size: 0.88rem;
            text-align: center;
        }

        .modal-resumen.visible {
            display: block;
        }

        .perfil-header {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: var(--space-2);
            text-align: center;
            margin-bottom: var(--space-4);
        }

        .badge {
            display: inline-block;
            background: var(--surface-2);
            color: var(--brand);
            padding: 0.25rem 0.75rem;
            border-radius: 999px;
            font-size: 0.8rem;
        }

        .perfil-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-3);
            margin-bottom: var(--space-4);
        }

        .stat-box {
            background: var(--surface-muted);
            border: 1px solid var(--line);
            border-radius: var(--radius);
            padding: var(--space-3);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.25rem;
        }

        .stat-label {
            font-size: 0.78rem;
            color: var(--muted);
        }

        .stat-value {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--brand);
        }

        .form-nota {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-2);
        }

        .form-nota .btn-guardar-mini {
            grid-column: 1 / -1;
            min-height: 44px;
            background: var(--brand);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            cursor: pointer;
        }

        .materias-desempeno {
            display: flex;
            flex-direction: column;
            gap: var(--space-2);
            font-size: 0.88rem;
            color: var(--muted);
        }

        .empty-state {
            padding: var(--space-8) var(--space-4);
            text-align: center;
            color: var(--muted);
        }
    </style>
</head>
<body class="app-body">
    <Navigation currentPath="/asistencias" />

    <main class="page page-stack">
        <header class="page-header">
            <div class="header-content">
                <p class="eyebrow">Control diario</p>
                <h1>Control de Asistencias</h1>
            </div>
            <div class="hero-actions">
                <button id="btn-tomar-lista" class="btn btn-primary">Tomar Lista</button>
                <button id="btn-exportar-asistencia" class="btn btn-secondary">Exportar</button>
            </div>
        </header>

        <section class="panel" aria-label="Filtros">
            <div class="filters-grid filtros">
                <input type="date" id="filtro-fecha" aria-label="Fecha" />
                <select id="filtro-escuela" aria-label="Escuela"><option value="">Todas las Escuelas</option></select>
                <select id="filtro-curso" aria-label="Curso"><option value="">Todos los Cursos</option></select>
                <select id="filtro-turno" aria-label="Turno">
                    <option value="">Todos los Turnos</option>
                    <option value="Mañana">Mañana</option>
                    <option value="Tarde">Tarde</option>
                    <option value="Noche">Noche</option>
                </select>
                <select id="filtro-materia" aria-label="Materia"><option value="">Todas las Materias</option></select>
            </div>
        </section>

        <!-- Modal: Tomar Lista -->
        <dialog id="modal-tomar-lista" class="modal">
            <div class="modal-content" style="text-align:center;">
                <button id="btn-cerrar-lista" class="btn-cerrar" aria-label="Cerrar">×</button>

                <h2>Tomando Lista</h2>
                <span id="progreso-lista" class="modal-progreso">Alumno 1 de X</span>

                <div class="modal-avatar-wrap">
                    <img id="lista-foto" src="" alt="Foto del alumno" class="avatar" />
                    <h2 id="lista-nombre">Nombre</h2>
                    <p id="lista-curso" style="color:#8b90a0;font-size:0.9rem;">Curso - Turno</p>
                </div>

                <div class="modal-acciones-lista">
                    <button id="btn-lista-ausente" class="btn btn-ausente">Ausente</button>
                    <button id="btn-lista-presente" class="btn btn-presente">Presente</button>
                </div>

                <p id="resumen-lista" class="modal-resumen"></p>

                <div class="modal-nav">
                    <button id="btn-lista-prev" class="btn btn-secondary btn-sm">← Anterior</button>
                    <button id="btn-lista-next" class="btn btn-secondary btn-sm">Siguiente →</button>
                </div>

                <div class="modal-footer">
                    <button id="btn-enviar-lista" class="btn btn-secondary" disabled>Enviar lista</button>
                    <button id="btn-exportar-lista-modal" class="btn btn-secondary" disabled>Exportar Excel</button>
                </div>
            </div>
        </dialog>

        <!-- Lista de alumnos -->
        <section class="panel" id="lista-asistencia" aria-label="Alumnos">
            <p class="empty-state">Selecciona los filtros para ver los alumnos.</p>
        </section>

        <!-- Modal: Perfil Alumno -->
        <dialog id="modal-perfil" class="modal">
            <div class="modal-content">
                <button id="btn-cerrar-modal" class="btn-cerrar" aria-label="Cerrar">×</button>

                <header class="perfil-header">
                    <img id="perfil-foto" src="" alt="Foto de perfil" class="avatar" />
                    <h2 id="perfil-nombre">Nombre del Alumno</h2>
                    <span id="perfil-curso" class="badge">Curso - Turno</span>
                </header>

                <div class="perfil-stats">
                    <div class="stat-box">
                        <span class="stat-label">Promedio</span>
                        <span id="perfil-promedio" class="stat-value">-</span>
                    </div>
                    <div class="stat-box">
                        <span class="stat-label">Notas</span>
                        <span id="perfil-cant-notas" class="stat-value">0</span>
                    </div>
                </div>

                <section class="perfil-detalles">
                    <h3>Cargar Nueva Nota</h3>
                    <div class="form-nota">
                        <select id="nota-materia" aria-label="Materia">
                            <option value="">Materia</option>
                        </select>
                        <select id="nota-tipo" aria-label="Tipo de nota">
                            <option value="Evaluacion">Evaluación</option>
                            <option value="Trabajo Practico">Trabajo Práctico</option>
                            <option value="Participacion">Participación</option>
                        </select>
                        <input type="number" id="nota-valor" placeholder="Nota (1-10)" min="1" max="10" aria-label="Valor de nota" />
                        <input type="text" id="nota-desc" placeholder="Tema" aria-label="Tema" />
                        <button id="btn-guardar-nota" class="btn-guardar-mini">Cargar Nota</button>
                    </div>

                    <h3>Desempeño por Materia</h3>
                    <div id="materias-desempeno" class="materias-desempeno"></div>
                </section>
            </div>
        </dialog>
    </main>

    <script>
      import { initMobileNav } from '../scripts/ui-nav.js';
      initMobileNav();
    </script>
    <script is:inline>
        let alumnosFiltradosActuales = [];
        let indiceLista = 0;
        let alumnoSeleccionadoId = null;
        const modalPerfil = document.getElementById('modal-perfil');
        const modalLista = document.getElementById('modal-tomar-lista');

        const listaUI = document.getElementById('lista-asistencia');
        const filtroFecha = document.getElementById('filtro-fecha');
        const filtroEscuela = document.getElementById('filtro-escuela');
        const filtroCurso = document.getElementById('filtro-curso');
        const filtroTurno = document.getElementById('filtro-turno');
        const filtroMateria = document.getElementById('filtro-materia');

        document.addEventListener('DOMContentLoaded', () => {
            filtroFecha.valueAsDate = new Date();
            cargarFiltrosDinamicos();
            renderizarLista();

            [filtroEscuela, filtroCurso, filtroTurno, filtroMateria, filtroFecha].forEach(el => {
                el.addEventListener('change', renderizarLista);
            });

            document.getElementById('btn-cerrar-modal')?.addEventListener('click', () => modalPerfil.close());
            document.getElementById('btn-guardar-nota')?.addEventListener('click', guardarNotaDesdeAsistencia);
            document.getElementById('btn-tomar-lista')?.addEventListener('click', iniciarModoLista);
            document.getElementById('btn-exportar-asistencia')?.addEventListener('click', exportarListaExcel);
            document.getElementById('btn-cerrar-lista')?.addEventListener('click', () => {
                modalLista.close();
                renderizarLista();
            });

            document.getElementById('btn-lista-presente')?.addEventListener('click', () => registrarYAvanzar('Presente'));
            document.getElementById('btn-lista-ausente')?.addEventListener('click', () => registrarYAvanzar('Ausente'));
            document.getElementById('btn-lista-prev')?.addEventListener('click', () => moverIndice(-1));
            document.getElementById('btn-lista-next')?.addEventListener('click', () => moverIndice(1));
            document.getElementById('btn-enviar-lista')?.addEventListener('click', enviarListaTomada);
            document.getElementById('btn-exportar-lista-modal')?.addEventListener('click', exportarListaExcel);
        });

        function cargarFiltrosDinamicos() {
            const alumnos = JSON.parse(localStorage.getItem('alumnos') || '[]');
            const materias = JSON.parse(localStorage.getItem('materias') || '[]');

            const escuelas = [...new Set(alumnos.map(a => a.escuela).filter(Boolean))];
            const cursos = [...new Set(alumnos.map(a => a.curso).filter(Boolean))];

            escuelas.forEach(esc => {
                filtroEscuela.innerHTML += `<option value="${escaparHtml(esc)}">${escaparHtml(esc)}</option>`;
            });
            cursos.forEach(cur => {
                filtroCurso.innerHTML += `<option value="${escaparHtml(cur)}">${escaparHtml(cur)}</option>`;
            });
            materias.forEach(mat => {
                filtroMateria.innerHTML += `<option value="${escaparHtml(mat.id)}">${escaparHtml(mat.nombre)}</option>`;
            });
        }

        function renderizarLista() {
            const alumnos = JSON.parse(localStorage.getItem('alumnos') || '[]');
            const materias = JSON.parse(localStorage.getItem('materias') || '[]');

            const escSel = filtroEscuela.value;
            const curSel = filtroCurso.value;
            const turSel = filtroTurno.value;
            const matSel = filtroMateria.value;

            let filtrados = alumnos.filter(al => {
                return (!escSel || al.escuela === escSel) &&
                    (!curSel || al.curso === curSel) &&
                    (!turSel || al.turno === turSel);
            });

            if (matSel) {
                const materia = materias.find(m => m.id === matSel);
                filtrados = materia ? filtrados.filter(al => materia.alumnosIds.includes(al.id)) : [];
            }

            alumnosFiltradosActuales = filtrados;

            if (filtrados.length === 0) {
                listaUI.innerHTML = '<p class="empty-state">No hay alumnos que coincidan con estos filtros.</p>';
                return;
            }

            listaUI.innerHTML = filtrados.map(al => {
                const estado = obtenerEstadoAsistencia(al.id);
                const estadoClase = estado ? estado.toLowerCase() : '';
                const textoEstado = estado ? `Lista tomada: ${estado}` : 'Sin tomar';
                const textoPresente = estado === 'Presente' ? 'Quitar Presente' : 'Presente';
                const textoAusente = estado === 'Ausente' ? 'Quitar Ausente' : 'Ausente';

                return `
                    <article class="alumno-fila">
                        <div class="alumno-info">
                            <strong>${escaparHtml(al.nombre)}</strong>
                            <small>(${escaparHtml(al.curso)} - ${escaparHtml(al.turno)})</small>
                            <br>
                            <span class="estado-asistencia ${estadoClase}">${textoEstado}</span>
                        </div>
                        <div class="lista-acciones">
                            <button class="btn btn-sm ${estado === 'Presente' ? 'btn-quitar' : 'btn-presente'}" onclick="toggleAsistencia(${al.id}, 'Presente')">${textoPresente}</button>
                            <button class="btn btn-sm ${estado === 'Ausente' ? 'btn-quitar' : 'btn-ausente'}" onclick="toggleAsistencia(${al.id}, 'Ausente')">${textoAusente}</button>
                            <button class="btn btn-sm btn-perfil" onclick="abrirPerfilAlumno(${al.id})">Ver Perfil</button>
                        </div>
                    </article>
                `;
            }).join('');
        }

        function obtenerDatosAsistencia() {
            return {
                fecha: filtroFecha.value,
                materiaId: filtroMateria.value || 'General'
            };
        }

        function obtenerRegistroAsistencia(alumnoId) {
            const { fecha, materiaId } = obtenerDatosAsistencia();
            const registroAsistencias = JSON.parse(localStorage.getItem('asistencias') || '[]');
            return registroAsistencias.find(a =>
                a.alumnoId === alumnoId && a.fecha === fecha && a.materiaId === materiaId
            );
        }

        function obtenerEstadoAsistencia(alumnoId) {
            const asistencia = obtenerRegistroAsistencia(alumnoId);
            if (!asistencia) return null;
            return asistencia.estado === 'A' ? 'Ausente' : asistencia.estado;
        }

        function guardarAsistencia(alumnoId, estado) {
            const { fecha, materiaId } = obtenerDatosAsistencia();
            if (!fecha) return alert("Selecciona una fecha.");

            const registroAsistencias = JSON.parse(localStorage.getItem('asistencias') || '[]');
            const index = registroAsistencias.findIndex(a =>
                a.alumnoId === alumnoId && a.fecha === fecha && a.materiaId === materiaId
            );

            if (!estado) {
                if (index !== -1) registroAsistencias.splice(index, 1);
                localStorage.setItem('asistencias', JSON.stringify(registroAsistencias));
                return;
            }

            const nuevaAsistencia = { id: Date.now(), alumnoId, materiaId, fecha, estado };

            if (index !== -1) registroAsistencias[index] = nuevaAsistencia;
            else registroAsistencias.push(nuevaAsistencia);

            localStorage.setItem('asistencias', JSON.stringify(registroAsistencias));
        }

        function toggleAsistencia(alumnoId, estado) {
            const estadoActual = obtenerEstadoAsistencia(alumnoId);
            guardarAsistencia(alumnoId, estadoActual === estado ? null : estado);
            renderizarLista();
            if (modalLista.open) actualizarVistaModalLista();
        }

        function abrirPerfilAlumno(id) {
            alumnoSeleccionadoId = id;
            const alumnos = JSON.parse(localStorage.getItem('alumnos') || '[]');
            const alumno = alumnos.find(a => a.id === id);
            const materias = JSON.parse(localStorage.getItem('materias') || '[]');
            const materiasAlumno = materias.filter(m => m.alumnosIds.includes(id));

            if (alumno && modalPerfil) {
                if (!alumno.notas) alumno.notas = [];

                document.getElementById('perfil-foto').src = `https://api.dicebear.com/7.x/avataaars/svg?seed=${alumno.id}`;
                document.getElementById('perfil-nombre').textContent = alumno.nombre;
                document.getElementById('perfil-curso').textContent = `${alumno.curso} - Turno ${alumno.turno}`;

                const promedio = alumno.notas.length > 0
                    ? (alumno.notas.reduce((acc, n) => acc + n.valor, 0) / alumno.notas.length).toFixed(2)
                    : "-";
                document.getElementById('perfil-promedio').textContent = promedio;
                document.getElementById('perfil-cant-notas').textContent = alumno.notas.length;

                renderizarMateriaSelect(materiasAlumno);
                renderizarDesempeno(alumno.notas, materiasAlumno);
                modalPerfil.showModal();
            }
        }

        function renderizarMateriaSelect(materias) {
            const select = document.getElementById('nota-materia');
            if (!select) return;
            select.innerHTML = '<option value="">Seleccionar Materia</option>' +
                materias.map(m => `<option value="${escaparHtml(m.id)}">${escaparHtml(m.nombre)}</option>`).join('');
        }

        function renderizarDesempeno(notas, materias) {
            const contenedor = document.getElementById('materias-desempeno');
            if (!contenedor) return;
            contenedor.innerHTML = materias.map(m => {
                const notasMateria = notas.filter(n => n.materiaId === m.id);
                return `<div><strong>${escaparHtml(m.nombre)}:</strong> ${notasMateria.map(n => escaparHtml(n.valor)).join(', ') || 'Sin notas'}</div>`;
            }).join('');
        }

        function iniciarModoLista() {
            if (alumnosFiltradosActuales.length === 0) {
                return alert("No hay alumnos para tomar lista con los filtros actuales.");
            }
            indiceLista = 0;
            actualizarVistaModalLista();
            modalLista.showModal();
        }

        function actualizarVistaModalLista() {
            const alumno = alumnosFiltradosActuales[indiceLista];
            const estadoActual = obtenerEstadoAsistencia(alumno.id);
            const resumenLista = obtenerResumenLista();

            document.getElementById('progreso-lista').textContent = `Alumno ${indiceLista + 1} de ${alumnosFiltradosActuales.length}`;
            document.getElementById('lista-foto').src = `https://api.dicebear.com/7.x/avataaars/svg?seed=${alumno.id}`;
            document.getElementById('lista-nombre').textContent = alumno.nombre;
            document.getElementById('lista-curso').textContent = `${alumno.curso} - ${alumno.turno}`;
            document.getElementById('btn-lista-presente').textContent = estadoActual === 'Presente' ? 'Quitar Presente' : 'Presente';
            document.getElementById('btn-lista-ausente').textContent = estadoActual === 'Ausente' ? 'Quitar Ausente' : 'Ausente';

            const btnPrev = document.getElementById('btn-lista-prev');
            const btnNext = document.getElementById('btn-lista-next');
            btnPrev.disabled = indiceLista === 0;
            btnNext.disabled = indiceLista === alumnosFiltradosActuales.length - 1;

            const resumen = document.getElementById('resumen-lista');
            resumen.textContent = `${resumenLista.tomados} de ${resumenLista.total} alumnos tomados. Presentes: ${resumenLista.presentes}. Ausentes: ${resumenLista.ausentes}.`;
            resumen.classList.toggle('visible', resumenLista.tomados > 0);

            const listaCompleta = resumenLista.total > 0 && resumenLista.tomados === resumenLista.total;
            document.getElementById('btn-enviar-lista').disabled = !listaCompleta;
            document.getElementById('btn-exportar-lista-modal').disabled = !listaCompleta;
        }

        function registrarYAvanzar(estado) {
            const alumno = alumnosFiltradosActuales[indiceLista];
            const estadoActual = obtenerEstadoAsistencia(alumno.id);

            if (estadoActual === estado) {
                guardarAsistencia(alumno.id, null);
                actualizarVistaModalLista();
                renderizarLista();
                return;
            }

            guardarAsistencia(alumno.id, estado);

            if (indiceLista < alumnosFiltradosActuales.length - 1) {
                indiceLista++;
                actualizarVistaModalLista();
            } else {
                actualizarVistaModalLista();
                const resumen = obtenerResumenLista();
                if (resumen.tomados === resumen.total) {
                    alert("Terminaste de tomar lista. Ahora podes enviarla o exportarla.");
                }
            }
            renderizarLista();
        }

        function moverIndice(direccion) {
            const nuevoIndice = indiceLista + direccion;
            if (nuevoIndice >= 0 && nuevoIndice < alumnosFiltradosActuales.length) {
                indiceLista = nuevoIndice;
                actualizarVistaModalLista();
            }
        }

        function obtenerResumenLista() {
            const estados = alumnosFiltradosActuales.map(al => obtenerEstadoAsistencia(al.id));
            const presentes = estados.filter(estado => estado === 'Presente').length;
            const ausentes = estados.filter(estado => estado === 'Ausente').length;
            return {
                total: alumnosFiltradosActuales.length,
                tomados: presentes + ausentes,
                presentes,
                ausentes
            };
        }

        function enviarListaTomada() {
            const resumen = obtenerResumenLista();
            if (resumen.tomados !== resumen.total) {
                alert("Todavia faltan alumnos por tomar.");
                return;
            }

            const listasEnviadas = JSON.parse(localStorage.getItem('listas_enviadas') || '[]');
            const { fecha, materiaId } = obtenerDatosAsistencia();
            const alumnosIds = alumnosFiltradosActuales.map(al => al.id);
            const clave = `${fecha}-${materiaId}-${alumnosIds.join('_')}`;
            const registro = {
                id: clave,
                fecha,
                materiaId,
                alumnosIds,
                resumen,
                enviadaEn: new Date().toISOString()
            };
            const index = listasEnviadas.findIndex(lista => lista.id === clave);
            if (index !== -1) listasEnviadas[index] = registro;
            else listasEnviadas.push(registro);

            localStorage.setItem('listas_enviadas', JSON.stringify(listasEnviadas));
            alert("Lista enviada correctamente.");
            modalLista.close();
            renderizarLista();
        }

        function exportarListaExcel() {
            if (alumnosFiltradosActuales.length === 0) {
                return alert("No hay alumnos para exportar con los filtros actuales.");
            }

            const { fecha, materiaId } = obtenerDatosAsistencia();
            const materias = JSON.parse(localStorage.getItem('materias') || '[]');
            const materia = materias.find(m => m.id === materiaId);
            const nombreMateria = materia?.nombre || 'General';
            const filas = alumnosFiltradosActuales.map(al => ({
                nombre: al.nombre,
                curso: al.curso,
                turno: al.turno,
                escuela: al.escuela || '',
                estado: obtenerEstadoAsistencia(al.id) || 'Sin tomar'
            }));

            const html = `
                <html>
                <head><meta charset="utf-8" /></head>
                <body>
                    <table border="1">
                        <tr><th colspan="5">Lista de asistencia - ${escaparHtml(fecha)} - ${escaparHtml(nombreMateria)}</th></tr>
                        <tr>
                            <th>Alumno</th><th>Curso</th><th>Turno</th><th>Escuela</th><th>Estado</th>
                        </tr>
                        ${filas.map(fila => `
                            <tr>
                                <td>${escaparHtml(fila.nombre)}</td>
                                <td>${escaparHtml(fila.curso)}</td>
                                <td>${escaparHtml(fila.turno)}</td>
                                <td>${escaparHtml(fila.escuela)}</td>
                                <td>${escaparHtml(fila.estado)}</td>
                            </tr>
                        `).join('')}
                    </table>
                </body>
                </html>
            `;

            const blob = new Blob([html], { type: 'application/vnd.ms-excel;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = `asistencia-${fecha || 'sin-fecha'}-${nombreMateria.replace(/\s+/g, '-')}.xls`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
        }

        function escaparHtml(valor) {
            return String(valor ?? '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }

        function guardarNotaDesdeAsistencia() {
            const valor = parseFloat(document.getElementById('nota-valor').value);
            const materiaId = document.getElementById('nota-materia').value;
            if (!valor || !materiaId) return alert("Faltan datos");

            const alumnos = JSON.parse(localStorage.getItem('alumnos') || '[]');
            const idx = alumnos.findIndex(a => a.id === alumnoSeleccionadoId);

            if (idx !== -1) {
                if (!alumnos[idx].notas) alumnos[idx].notas = [];
                alumnos[idx].notas.push({
                    valor,
                    materiaId,
                    tipo: document.getElementById('nota-tipo').value,
                    fecha: new Date().toLocaleDateString()
                });
                localStorage.setItem('alumnos', JSON.stringify(alumnos));
                abrirPerfilAlumno(alumnoSeleccionadoId);
            }
        }
    </script>
</body>
</html>