---
// src/components/RegistroAlumnos.astro
import '../styles/global.css';

interface Nota {
    id: number;
    materiaId?: string;
    materiaNombre?: string;
    tipo: 'Evaluación' | 'Trabajo Práctico' | 'Participación';
    valor: number;
    descripcion: string;
    fecha: string;
}

interface Alumno {
    id: number;
    nombre: string;
    curso: string;
    turno: string;
    escuela: string;
    notas: Nota[];
}

interface Materia {
    id: string;
    nombre: string;
    profesor: string;
    alumnosIds: number[];
    fechaCreacion: string;
}
---

<div class="modulo-registro panel">
    <h3>Registrar Nuevo Alumno</h3>
    <form id="form-alumno" class="form-grid">
        <input type="text" id="nombre" placeholder="Nombre Completo" required />
        
        <div class="input-group">
            <input type="text" id="curso" list="lista-cursos-sugeridos" placeholder="Curso (ej: 6to 1ra)" required />
            <datalist id="lista-cursos-sugeridos"></datalist>
            <label class="checkbox-label">
                <input type="checkbox" id="guardar-curso"> Recordar curso
            </label>
        </div>

        <select id="turno" required>
            <option value="">Seleccionar Turno</option>
            <option value="Mañana">Mañana</option>
            <option value="Tarde">Tarde</option>
            <option value="Vespertino">Vespertino</option>
        </select>

        <div class="input-group">
            <input type="text" id="escuela" list="lista-escuelas-sugeridas" placeholder="Escuela" required />
            <datalist id="lista-escuelas-sugeridas"></datalist>
            <label class="checkbox-label">
                <input type="checkbox" id="guardar-escuela"> Recordar escuela
            </label>
        </div>

        <button type="submit" class="btn btn-primary btn-block">Guardar Alumno</button>
    </form>

    <hr />

    <h3>Lista de Alumnos</h3>
    <p class="hint">Hacé clic en un alumno para ver más opciones</p>
    <ul id="lista-alumnos" class="alumno-list"></ul>
</div>

<dialog id="modal-perfil" class="modal">
    <div class="modal-content">
        <button id="btn-cerrar-modal" class="btn-cerrar">✖</button>
        
        <div class="perfil-header">
            <img id="perfil-foto" src="" alt="Foto de perfil" class="avatar" />
            <h2 id="perfil-nombre">Nombre del Alumno</h2>
            <p id="perfil-curso" class="badge">Curso - Turno</p>
        </div>

        <div class="perfil-stats">
            <div class="stat-box">
                <span class="stat-label">Promedio</span>
                <span id="perfil-promedio" class="stat-value">-</span>
            </div>
            <div class="stat-box">
                <span class="stat-label">Notas</span>
                <span id="perfil-cant-notas" class="stat-value">0</span>
            </div>
        </div>

        <div class="perfil-detalles">
            <h3>Cargar Nueva Nota</h3>
            <div class="form-nota">
                <select id="nota-materia">
                    <option value="">Materia</option>
                </select>
                <select id="nota-tipo">
                    <option value="Evaluación">Evaluación</option>
                    <option value="Trabajo Práctico">Trabajo Práctico</option>
                    <option value="Participación">Participación</option>
                </select>
                <input type="number" id="nota-valor" placeholder="Nota" min="1" max="10">
                <input type="text" id="nota-desc" placeholder="Tema">
                <button id="btn-guardar-nota" class="btn btn-primary btn-block">Cargar</button>
            </div>

            <h3>Desempeño por Materia</h3>
            <div id="materias-desempeno" class="materias-desempeno"></div>
        </div>
    </div>
</dialog>

<script is:inline>
    const form = document.getElementById('form-alumno');
    const listaUI = document.getElementById('lista-alumnos');
    const dlCursos = document.getElementById('lista-cursos-sugeridos');
    const dlEscuelas = document.getElementById('lista-escuelas-sugeridas');
    const btnGuardarNota = document.getElementById('btn-guardar-nota');
    const modal = document.getElementById('modal-perfil');
    const btnCerrarModal = document.getElementById('btn-cerrar-modal');
    const materiaSelect = document.getElementById('nota-materia');
    
    let alumnoSeleccionadoId = null;
    // BORRAMOS EL ": Materia[]"
    let materiasAlumno = []; 

    document.addEventListener('DOMContentLoaded', () => {
        mostrarAlumnos();
        cargarSugerencias();
    });

    function cargarSugerencias() {
        const cursosGuardados = JSON.parse(localStorage.getItem('preferencias_cursos') || '[]');
        const escuelasGuardadas = JSON.parse(localStorage.getItem('preferencias_escuelas') || '[]');

        dlCursos.innerHTML = cursosGuardados.map(c => `<option value="${c}">`).join('');
        dlEscuelas.innerHTML = escuelasGuardadas.map(e => `<option value="${e}">`).join('');
    }

    // Guardar Alumno
    if (form) {
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            
            const nombreIn = document.getElementById('nombre');
            const cursoIn = document.getElementById('curso');
            const turnoIn = document.getElementById('turno');
            const escuelaIn = document.getElementById('escuela');
            const chkCurso = document.getElementById('guardar-curso');
            const chkEscuela = document.getElementById('guardar-escuela');

            if (chkCurso.checked) {
                const actuales = JSON.parse(localStorage.getItem('preferencias_cursos') || '[]');
                if (!actuales.includes(cursoIn.value)) {
                    actuales.push(cursoIn.value);
                    localStorage.setItem('preferencias_cursos', JSON.stringify(actuales));
                }
            }

            if (chkEscuela.checked) {
                const actuales = JSON.parse(localStorage.getItem('preferencias_escuelas') || '[]');
                if (!actuales.includes(escuelaIn.value)) {
                    actuales.push(escuelaIn.value);
                    localStorage.setItem('preferencias_escuelas', JSON.stringify(actuales));
                }
            }

            const nuevoAlumno = {
                id: Date.now(),
                nombre: nombreIn.value,
                curso: cursoIn.value,
                turno: turnoIn.value,
                escuela: escuelaIn.value,
                notas: []
            };

            const alumnos = JSON.parse(localStorage.getItem('alumnos') || '[]');
            alumnos.push(nuevoAlumno);
            localStorage.setItem('alumnos', JSON.stringify(alumnos));
            
            form.reset();
            mostrarAlumnos();
            cargarSugerencias();
        });
    }

    // Guardar Nota
    if (btnGuardarNota) {
        btnGuardarNota.addEventListener('click', () => {
            if (alumnoSeleccionadoId === null) return;

            const tipo = document.getElementById('nota-tipo').value;
            const materiaId = materiaSelect?.value || '';
            const valor = parseFloat(document.getElementById('nota-valor').value);
            const desc = document.getElementById('nota-desc').value;

            if (isNaN(valor) || valor < 1 || valor > 10) {
                alert("Por favor, ingresá una nota válida del 1 al 10");
                return;
            }

            // BORRAMOS EL ": Materia[]" AQUÍ TAMBIÉN
            const materias = JSON.parse(localStorage.getItem('materias') || '[]');
            const materia = materias.find(m => m.id === materiaId);

            const alumnos = JSON.parse(localStorage.getItem('alumnos') || '[]');
            const idx = alumnos.findIndex(a => a.id === alumnoSeleccionadoId);

            if (idx !== -1) {
                alumnos[idx].notas.push({
                    id: Date.now(),
                    materiaId: materia?.id,
                    materiaNombre: materia?.nombre || 'General',
                    tipo: tipo,
                    valor: valor,
                    descripcion: desc || 'Sin descripción',
                    fecha: new Date().toLocaleDateString()
                });

                localStorage.setItem('alumnos', JSON.stringify(alumnos));
                
                // Limpiar inputs y refrescar
                document.getElementById('nota-valor').value = '';
                document.getElementById('nota-desc').value = '';
                abrirPerfilAlumno(alumnoSeleccionadoId);
            }
        });
    }

    function mostrarAlumnos() {
        if (!listaUI) return;
        const alumnos = JSON.parse(localStorage.getItem('alumnos') || '[]');
        
        listaUI.innerHTML = alumnos.map((al) => `
            <li class="alumno-item" data-id="${al.id}">
                <div class="alumno-info">
                    <strong>${al.nombre}</strong>
                    <span class="badge">${al.curso} · Turno ${al.turno}</span>
                </div>
                <div class="btn-container">
                    <button class="btn btn-secondary btn-block btn-ver" data-id="${al.id}">Ver Alumno</button>
                </div>
            </li>
        `).reverse().join('');

        
    }

    // Delegación de eventos para la lista de alumnos
    if (listaUI) {
        listaUI.addEventListener('click', (e) => {
            const target = e.target;
            const item = target.closest('.alumno-item');
            
            if (!item) return;

            // Si hicimos clic en el botón "Ver Alumno"
            if (target.classList.contains('btn-ver')) {
                const alumnoId = parseInt(target.getAttribute('data-id') || '0');
                abrirPerfilAlumno(alumnoId);
                return;
            }

            // Si hicimos clic en cualquier otra parte del LI, desplegamos/ocultamos el botón
            document.querySelectorAll('.alumno-item').forEach(el => {
                if (el !== item) el.classList.remove('expandido');
            });
            item.classList.toggle('expandido');
        });
    }

    function abrirPerfilAlumno(id) {
    alumnoSeleccionadoId = id;
    const alumnos = JSON.parse(localStorage.getItem('alumnos') || '[]');
    const alumno = alumnos.find(a => a.id === id);

    const materias = JSON.parse(localStorage.getItem('materias') || '[]');
    materiasAlumno = materias.filter(m => m.alumnosIds.includes(id));

    if (alumno && modal) {
        // ✅ Garantizamos que notas sea siempre un array
        if (!alumno.notas) alumno.notas = [];

        document.getElementById('perfil-foto').src = `https://api.dicebear.com/7.x/avataaars/svg?seed=${alumno.id}&backgroundColor=b6e3f4`;
        document.getElementById('perfil-nombre').textContent = alumno.nombre;
        document.getElementById('perfil-curso').textContent = `${alumno.curso} - Turno ${alumno.turno}`;
        
        renderizarMateriaSelect(materiasAlumno);
        renderizarNotas(alumno.notas, materiasAlumno);
        modal.showModal();
    }
}

    function renderizarMateriaSelect(materias) {
        if (!materiaSelect) return;

        materiaSelect.innerHTML = [
            '<option value="">General</option>',
            ...materias.map(m => `<option value="${m.id}">${m.nombre}</option>`)
        ].join('');
    }

    function renderizarNotas(notas, materias) {
        const promedioLabel = document.getElementById('perfil-promedio');
        const cantLabel = document.getElementById('perfil-cant-notas');

        if (promedioLabel && cantLabel) {
            if (notas.length > 0) {
                const suma = notas.reduce((acc, curr) => acc + curr.valor, 0);
                promedioLabel.textContent = (suma / notas.length).toFixed(1);
                cantLabel.textContent = notas.length.toString();
            } else {
                promedioLabel.textContent = "-";
                cantLabel.textContent = "0";
            }
        }

        renderizarMateriasDesempeno(notas, materias);
    }

    function renderizarMateriasDesempeno(notas, materias) {
        const contenedor = document.getElementById('materias-desempeno');
        if (!contenedor) return;

        const grupos = materias.map(m => {
            const notasMateria = notas.filter(n => n.materiaId === m.id);
            const promedio = notasMateria.length > 0
                ? (notasMateria.reduce((acc, cur) => acc + cur.valor, 0) / notasMateria.length).toFixed(1)
                : "-";
            return {
                materia: m.nombre,
                notas: notasMateria,
                promedio
            };
        });

        const notasGenerales = notas.filter(n => !n.materiaId || !materias.some(m => m.id === n.materiaId));
        if (notasGenerales.length > 0) {
            grupos.push({
                materia: 'General',
                notas: notasGenerales,
                promedio: (notasGenerales.reduce((acc, cur) => acc + cur.valor, 0) / notasGenerales.length).toFixed(1)
            });
        }

        if (grupos.length === 0) {
            contenedor.innerHTML = '<p class="sin-notas">Este alumno no está inscrito en materias ni tiene notas registradas.</p>';
            return;
        }

        contenedor.innerHTML = grupos.map(g => `
            <div class="materia-desempeno-card">
                <div class="materia-desempeno-titulo">
                    <strong>${g.materia}</strong>
                    <span>${g.notas.length} notas</span>
                </div>
                <div class="materia-desempeno-lista">
                    ${g.notas.length > 0
                        ? g.notas.map(n => `<span class="nota-tag">${n.valor}</span>`).join('')
                        : '<em>Sin notas cargadas</em>'}
                </div>
                <div class="materia-desempeno-promedio">Promedio: ${g.promedio}</div>
            </div>
        `).join('');
    }

    if (btnCerrarModal && modal) {
        btnCerrarModal.addEventListener('click', () => {
            modal.close();
        });
    }
</script>

<style>
    .modulo-registro {
        padding: 0;
    }

    .modulo-registro h3 {
        margin-top: 0;
    }

    .form-grid {
        margin-bottom: var(--space-4);
    }

    .checkbox-label {
        font-size: 0.9rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    }

    .checkbox-label input {
        width: 1.1rem;
        min-width: 1.1rem;
        min-height: 1.1rem;
    }

    hr {
        border: 0;
        border-top: 1px solid var(--line);
        margin: var(--space-5) 0;
    }

    .hint {
        font-size: 0.85rem;
        color: var(--muted);
        margin-bottom: var(--space-3);
    }

    .alumno-list {
        list-style: none;
        padding: 0;
        display: grid;
        gap: var(--space-3);
    }

    .alumno-item {
        background: var(--surface-muted);
        border: 1px solid var(--line);
        border-left: 4px solid var(--brand);
        border-radius: var(--radius);
        overflow: hidden;
        cursor: pointer;
        transition: background var(--transition-fast);
    }

    .alumno-item:hover {
        background: var(--surface-2);
    }

    .alumno-info {
        padding: var(--space-4);
    }

    .btn-container {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        padding: 0 var(--space-4);
        transition: all 0.28s ease-out;
    }

    .alumno-item.expandido .btn-container {
        max-height: 72px;
        opacity: 1;
        padding-bottom: var(--space-4);
    }

    .badge {
        display: inline-block;
        margin-top: 0.35rem;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        background: var(--surface-2);
        color: var(--muted);
        font-size: 0.82rem;
    }

    .modal {
        width: min(560px, calc(100% - 32px));
        border: 0;
        padding: 0;
        color: var(--ink);
        background: transparent;
    }

    .modal::backdrop {
        background: rgba(11, 18, 15, 0.48);
    }

    .modal-content {
        position: relative;
        max-height: 86vh;
        overflow-y: auto;
        padding: var(--space-5);
        border: 1px solid var(--line);
        border-radius: calc(var(--radius) + 2px);
        background: var(--surface);
        box-shadow: var(--shadow);
        -webkit-overflow-scrolling: touch;
    }

    .btn-cerrar {
        position: absolute;
        top: var(--space-4);
        right: var(--space-4);
        min-height: 36px;
        padding: 0.35rem 0.55rem;
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        color: var(--muted);
        background: var(--surface-2);
        cursor: pointer;
    }

    .perfil-header {
        text-align: center;
        margin-bottom: var(--space-5);
    }

    .avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: var(--surface-2);
        margin-bottom: var(--space-3);
        border: 3px solid var(--brand);
    }

    .perfil-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3);
        background: var(--surface-muted);
        padding: var(--space-4);
        border-radius: var(--radius);
        margin-bottom: var(--space-5);
    }

    .stat-box {
        text-align: center;
    }

    .stat-label {
        display: block;
        font-size: 0.75rem;
        color: var(--muted);
        text-transform: uppercase;
    }

    .stat-value {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--brand);
    }

    .perfil-detalles h3 {
        font-size: 1rem;
        margin-bottom: var(--space-3);
        padding-bottom: var(--space-2);
        border-bottom: 1px solid var(--line);
    }

    .form-nota {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-2);
        margin-bottom: var(--space-4);
    }

    @media (min-width: 520px) {
        .form-nota {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .form-nota .btn {
            grid-column: 1 / -1;
        }
    }

    .materias-desempeno {
        display: grid;
        gap: var(--space-3);
    }

    .materia-desempeno-card {
        background: var(--surface-muted);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: var(--space-4);
    }

    .materia-desempeno-titulo {
        display: flex;
        justify-content: space-between;
        gap: var(--space-2);
        margin-bottom: var(--space-3);
        flex-wrap: wrap;
    }

    .materia-desempeno-lista {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-bottom: var(--space-3);
    }

    .materia-desempeno-promedio {
        color: var(--brand-strong);
        font-weight: 800;
    }

    .nota-tag {
        background: var(--surface-2);
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        font-size: 0.85rem;
    }

    .sin-notas {
        color: var(--muted);
    }

    @media (min-width: 720px) {
        .materias-desempeno {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
</style>