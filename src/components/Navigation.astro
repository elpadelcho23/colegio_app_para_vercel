---
const { currentPath = '/', spaEnabled = false } = Astro.props;
const user = Astro.locals.user;

const links = [
  { view: 'panel', label: 'Panel' },
  { view: 'registro', label: 'Alumnos' },
  { view: 'cursos', label: 'Cursos' },
  { view: 'asistencia', label: 'Asistencia' },
  { view: 'notas', label: 'Calificaciones' },
  { view: 'actividades', label: 'Actividades' },
  ...(user?.rol === 'admin' ? [{ href: '/admin/usuarios', label: 'Admin' }] : []),
];

const isActive = (view: string) => {
  if (!spaEnabled) {
    const href = view === 'panel' ? '/' : `/${view === 'registro' ? 'registro' : view}`;
    return view === 'panel' ? currentPath === '/' : currentPath.startsWith(href);
  }
  return false;
};
---

<header class="app-shell">
  <div class="institution-strip">
    <div>
      <strong>Escuela Técnica 1</strong>
      <span>Seguimiento escolar simple para docentes</span>
    </div>
    {user && <span>{user.nombre} - {user.rol}</span>}
  </div>
  <nav class="topbar" aria-label="Navegación principal">
    {spaEnabled ? (
      <button class="brand brand-button" type="button" data-spa-nav="panel" aria-label="Ir al panel principal">
        <span class="brand-mark">AC</span>
        <span>
          <strong>Aula Clara</strong>
          <small>Gestión docente</small>
        </span>
      </button>
    ) : (
      <a class="brand" href="/" aria-label="Ir al panel principal">
        <span class="brand-mark">AC</span>
        <span>
          <strong>Aula Clara</strong>
          <small>Gestión docente</small>
        </span>
      </a>
    )}

    <button
      class="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-controls="main-navigation-menu"
      aria-expanded="false"
      data-menu-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="nav-links" id="main-navigation-menu" data-nav-menu role="menu">
      <p class="nav-section-label">Menú</p>
      {links.map((link) => (
        'href' in link ? (
          <a
            href={link.href}
            class:list={[{ active: currentPath.startsWith(link.href) }]}
            aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
            role="menuitem"
          >
            {link.label}
          </a>
        ) : spaEnabled ? (
          <button
            type="button"
            class="nav-tab"
            data-spa-nav={link.view}
            role="menuitem"
          >
            {link.label}
          </button>
        ) : (
          <a
            href={link.view === 'panel' ? '/' : `/${link.view === 'registro' ? 'registro' : link.view}`}
            class:list={[{ active: isActive(link.view) }]}
            aria-current={isActive(link.view) ? 'page' : undefined}
            role="menuitem"
          >
            {link.label}
          </a>
        )
      ))}
      {user ? (
        <form method="post" action="/api/auth/logout" class="nav-form">
          <button type="submit">Salir</button>
        </form>
      ) : (
        <a href="/login" class:list={[{ active: currentPath === '/login' }]}>Login</a>
      )}
      <button class="theme-toggle" type="button" data-theme-toggle>Modo oscuro</button>
    </div>
  </nav>
</header>

<style>
  .brand-button {
    border: 0;
    background: transparent;
    cursor: pointer;
    text-align: left;
    color: inherit;
    font: inherit;
    padding: 0;
  }

  .nav-tab {
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    cursor: pointer;
    text-align: left;
    width: 100%;
    padding: 0.65rem 0.85rem;
    border-radius: var(--radius-sm);
  }

  .nav-tab.active,
  .nav-tab[aria-current='page'] {
    background: color-mix(in srgb, var(--brand) 14%, var(--surface));
    color: var(--brand);
    font-weight: 700;
  }
</style>
