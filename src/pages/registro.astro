---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registro de alumnos">
  <main class="page">
    <header class="page-header">
      <div>
        <p class="eyebrow">Alumnos</p>
        <h1>Registro simple</h1>
        <p>Nombre, curso, materias y contacto. El DNI queda como dato opcional.</p>
      </div>
      <a class="btn btn-secondary" href="/cursos">Organizar cursos</a>
    </header>

    <section class="grid-2">
      <form class="panel form-grid" data-student-form>
        <label>
          <span>Nombre completo</span>
          <input name="nombre" autocomplete="name" required />
        </label>
        <label>
          <span>DNI opcional</span>
          <input name="dni" inputmode="numeric" />
        </label>
        <label class="span-2">
          <span>Curso</span>
          <select name="cursoId" required></select>
        </label>
        <fieldset class="span-2 subject-picker">
          <legend>Materias del alumno</legend>
          <div class="checkbox-grid compact" data-student-subjects></div>
          <label>
            <span>Agregar materia si no esta en la lista</span>
            <input name="nuevaMateria" data-student-new-subject placeholder="Ej: Historia" />
          </label>
        </fieldset>
        <label class="span-2">
          <span>Tutor o contacto</span>
          <input name="tutor" />
        </label>
        <button class="btn btn-primary span-2" type="submit">Guardar alumno</button>
      </form>

      <div class="panel">
        <div class="section-title">
          <h2>Alumnos cargados</h2>
          <p>La lista muestra curso y promedio calculado en tiempo real.</p>
        </div>
        <div class="list" data-student-list></div>
      </div>
    </section>
  </main>
</Layout>
