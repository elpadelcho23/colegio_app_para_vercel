---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cursos">
  <main class="page page-stack" data-courses>
    <header class="page-header">
      <div class="header-content">
        <p class="eyebrow">Organización</p>
        <h1>Cursos y divisiones</h1>
        <p>Base de trabajo para inscripciones, asistencia y reportes.</p>
      </div>
      <a class="btn btn-secondary btn-block" href="/registro">Cargar alumnos</a>
    </header>

    <section class="responsive-grid">
      <form class="panel form-grid" data-course-form>
        <div class="section-title">
          <h2>Nuevo curso</h2>
        </div>
        <label>
          <span>Escuela</span>
          <input name="escuela" required />
        </label>
        <label>
          <span>Curso</span>
          <input name="nombre" placeholder="Ej: 6to 1ra" required />
        </label>
        <label>
          <span>Turno</span>
          <select name="turno" required>
            <option value="">Seleccionar turno</option>
            <option>Mañana</option>
            <option>Tarde</option>
            <option>Noche</option>
          </select>
        </label>
        <button class="btn btn-primary btn-block" type="submit">Crear curso</button>
      </form>

      <section class="panel">
        <div class="section-title">
          <h2>Cursos activos</h2>
          <p>Resumen de alumnos y materias por división.</p>
        </div>
        <div class="list" data-course-list></div>
      </section>
    </section>
  </main>
</Layout>
