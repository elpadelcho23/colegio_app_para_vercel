# Copiá este archivo a .env y completá los valores (no subas .env al repositorio).

GROQ_API_KEY=tu_clave_groq_aqui

# Límites opcionales para la cola de solicitudes a Groq (50 docentes concurrentes)
GROQ_MAX_CONCURRENT=6
GROQ_MAX_RPM=28

# Intervalo de backups automáticos (horas)
BACKUP_INTERVAL_HOURS=24
